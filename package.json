{
  "name": "@lira/design-system",
  "version": "1.0.0",
  "description": "Lira Design System — mobile design tokens and React Native components for Lira for Women.",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "main": "./dist/js/tokens.cjs.js",
  "module": "./dist/js/tokens.esm.js",
  "types": "./dist/js/tokens.d.ts",
  "files": [
    "dist",
    "src",
    "tokens",
    "scripts",
    "assets",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/js/tokens.d.ts",
      "import": "./dist/js/tokens.esm.js",
      "require": "./dist/js/tokens.cjs.js"
    },
    "./react-native": {
      "react-native": "./src/react-native/index.ts",
      "types": "./src/react-native/index.ts",
      "import": "./src/react-native/index.ts",
      "default": "./src/react-native/index.ts"
    },
    "./react-native/theme": {
      "types": "./dist/react-native/theme.ts",
      "import": "./dist/react-native/theme.ts"
    },
    "./chart-utils": {
      "types": "./src/chart-utils/index.ts",
      "import": "./src/chart-utils/index.ts"
    },
    "./assets/*": "./assets/*"
  },
  "scripts": {
    "build:tokens": "node scripts/build-tokens.mjs",
    "build": "node scripts/build-tokens.mjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.74",
    "@phosphor-icons/react-native": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "react-native": { "optional": true },
    "@phosphor-icons/react-native": { "optional": true }
  },
  "devDependencies": {
    "typescript": "~5.9.0"
  },
  "engines": {
    "node": ">=18"
  }
}
