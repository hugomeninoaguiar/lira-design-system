{
  "$description": "Semantic tokens for Lira for Professionals (web). Cooler clinical feel — restrained off-white/cool neutrals, deep sage as primary accent, tighter radii, evidence/clinical typographic weight. Inherits all primitive scales.",
  "semantic": {
    "background": {
      "app":          { "value": "{color.cool.50}", "$description": "Page background — cool off-white" },
      "surface":      { "value": "{color.neutral.0}" },
      "subtle":       { "value": "{color.cool.100}" },
      "heroPrimary":  { "value": "{color.cool.50}", "$description": "Hero — restrained, no peach" },
      "heroSecondary":{ "value": "{color.neutral.0}" },
      "accentSoft":   { "value": "{color.green.100}", "$description": "Sage tint for callouts" },
      "accentDeep":   { "value": "{color.green.500}" },
      "evidenceCard": { "value": "{color.neutral.0}", "$description": "Card for evidence / DSM-5-TR content" },
      "warmCallout":  { "value": "{color.amber.50}", "$description": "Reserved for editorial callouts only" }
    },
    "text": {
      "primary":   { "value": "{color.cool.900}", "$description": "Clinical, high-contrast body" },
      "secondary": { "value": "{color.cool.500}" },
      "muted":     { "value": "{color.cool.300}" },
      "onAccent":  { "value": "{color.neutral.0}" },
      "onPrimary": { "value": "{color.neutral.0}" },
      "link":      { "value": "{color.green.600}" },
      "evidence":  { "value": "{color.green.700}", "$description": "Citation / evidence references" }
    },
    "border": {
      "default": { "value": "{color.cool.200}" },
      "subtle":  { "value": "{color.cool.100}" },
      "strong":  { "value": "{color.cool.300}" },
      "focus":   { "value": "{color.green.500}" }
    },
    "action": {
      "primary":       { "value": "{color.green.500}" },
      "primaryHover":  { "value": "{color.green.600}" },
      "primarySoft":   { "value": "{color.green.100}" },
      "secondary":     { "value": "{color.neutral.0}" },
      "destructive":   { "value": "{color.dustyRed.400}" }
    },
    "accent": {
      "primary": { "value": "{color.sage.500}" },
      "subtle":  { "value": "{color.green.100}" },
      "warm":    { "value": "{color.amber.500}", "$description": "Sparingly — editorial underlines" }
    },
    "feedback": {
      "success": { "fg": { "value": "{color.feedback.successFg}" }, "bg": { "value": "{color.feedback.successBg}" } },
      "warning": { "fg": { "value": "{color.feedback.warningFg}" }, "bg": { "value": "{color.feedback.warningBg}" } },
      "error":   { "fg": { "value": "{color.feedback.errorFg}" },   "bg": { "value": "{color.feedback.errorBg}" } },
      "info":    { "fg": { "value": "{color.feedback.infoFg}" },    "bg": { "value": "{color.feedback.infoBg}" } }
    },
    "radius": {
      "card":   { "value": "{radius.md}", "$description": "16 — tighter, more clinical than the Women surface" },
      "cardLg": { "value": "{radius.lg}" },
      "button": { "value": "{radius.pill}" },
      "input":  { "value": "{radius.sm}" }
    },
    "data": {
      "clinical": {
        "green":  { "value": "{color.data.clinical.green}" },
        "teal":   { "value": "{color.data.clinical.teal}" },
        "sand":   { "value": "{color.data.clinical.sand}" },
        "plum":   { "value": "{color.data.clinical.plum}" },
        "slate":  { "value": "{color.data.clinical.slate}" }
      }
    }
  }
}
